# Copy to terraform.tfvars and fill in real values.
# DO NOT commit terraform.tfvars (it contains secrets).

do_token             = "dop_v1_..."
cf_api_token         = "..."
cf_zone_id           = "..."
domain               = "example.com"
ssh_key_fingerprints = ["ab:cd:ef:..."]
admin_ips            = ["203.0.113.5/32"]
release_tag          = "v1.2.3"
region               = "fra1"

# Droplet size slugs — adjust to match your resource requirements.
# primary_size      = "s-4vcpu-16gb-amd"     # 4 vCPU / 16 GB
# secondary_size    = "s-2vcpu-8gb-amd"       # 2 vCPU / 8 GB

# PIR hosts (vote-nullifier-pir) — both need Premium Intel (AVX-512).
# pir_primary_size       = "g-8vcpu-32gb-intel"   # 8 vCPU / 32 GB
# pir_backup_size        = "m-4vcpu-32gb-intel"   # 4 vCPU / 32 GB
# pir_volume_size        = 100                     # GB per PIR data volume
# pir_release_tag        = "latest"                # vote-nullifier-pir release tag
# pir_snapshot_url       = "https://vote.fra1.digitaloceanspaces.com"
# pir_resync_on_calendar = "*-*-* 03:00:00"        # systemd OnCalendar= for re-pull
