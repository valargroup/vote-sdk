# vote-sdk local development environment
# Copy to .env and fill in values:  cp .env.example .env

# Admin private keys (required).
# Comma-separated list of 64-character hex secp256k1 private keys. Every
# derived address becomes an admin at genesis (any-of-N); the stake pool is
# split evenly across the set. For a single-admin chain, provide exactly one
# key. Generate one with:  openssl rand -hex 32
VM_PRIVKEYS=
