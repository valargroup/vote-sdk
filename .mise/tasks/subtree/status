#!/usr/bin/env bash
#MISE description="Show subtree sync status (divergence between monorepo and fork)"
#MISE quiet=true
set -euo pipefail

NAME="${1:-}"
if [ -z "$NAME" ]; then
    echo "Usage: mise run subtree:status <name>"
    echo "Supported: vote-nullifier-pir"
    exit 1
fi

case "$NAME" in
  vote-nullifier-pir)
    PREFIX="vote-nullifier-pir"
    REMOTE="sub-nullifier-pir"
    REPO="valargroup/vote-nullifier-pir"
    BRANCH="main"
    REMOTE_URL="git@github.com:valargroup/vote-nullifier-pir.git"
    ;;
  *)
    echo "Unknown subtree: $NAME"
    echo "Supported: vote-nullifier-pir"
    exit 1
    ;;
esac

# Ensure remote exists
if ! git remote get-url "$REMOTE" &>/dev/null; then
    printf '\033[2mAdding remote %s → %s\033[0m\n' "$REMOTE" "$REMOTE_URL"
    git remote add "$REMOTE" "$REMOTE_URL"
fi

printf '\033[2mFetching %s/%s…\033[0m\n' "$REMOTE" "$BRANCH"
git fetch "$REMOTE" "$BRANCH" --quiet

echo ""
printf '\033[1m%s\033[0m  (%s → %s/%s)\n' "$NAME" "$PREFIX" "$REPO" "$BRANCH"
echo ""

# Uncommitted changes in the prefix
DIRTY=$(git status --porcelain -- "$PREFIX/" 2>/dev/null || true)
if [ -n "$DIRTY" ]; then
    printf '  \033[33m⚠ uncommitted changes\033[0m\n'
    echo "$DIRTY" | sed 's/^/    /'
    echo ""
fi

# Find the last subtree merge (squash pull) to use as a baseline.
# git log | head can SIGPIPE; read into variable first to avoid pipefail.
SYNC_LOG=$(git log --all --grep="Squashed '$PREFIX/'" --format="%H %s" -1 2>/dev/null || true)
if [ -z "$SYNC_LOG" ]; then
    SYNC_LOG=$(git log --all --grep="as '$PREFIX'" --format="%H %s" -1 2>/dev/null || true)
fi

if [ -n "$SYNC_LOG" ]; then
    SYNC_SHA="${SYNC_LOG%% *}"
    SYNC_MSG="${SYNC_LOG#* }"
    printf '  last sync   %s  %s\n' "${SYNC_SHA:0:12}" "$SYNC_MSG"
else
    printf '  \033[33mlast sync   unknown (no subtree merge found)\033[0m\n'
fi

# Monorepo commits touching the prefix since last sync
MONO_LOG=$(git log --oneline HEAD -- "$PREFIX/" 2>/dev/null || true)
MONO_AHEAD=0
if [ -n "$MONO_LOG" ]; then
    MONO_AHEAD=$(echo "$MONO_LOG" | wc -l | tr -d ' ')
fi
if [ "$MONO_AHEAD" -gt 0 ]; then
    printf '  \033[36mmonorepo\033[0m    %s commit(s) touching %s/\n' "$MONO_AHEAD" "$PREFIX"
    echo "$MONO_LOG" | head -5 | sed 's/^/              /'
    if [ "$MONO_AHEAD" -gt 5 ]; then
        printf '              … and %s more\n' "$((MONO_AHEAD - 5))"
    fi
else
    printf '  monorepo    \033[32min sync\033[0m (no local commits touching %s/)\n' "$PREFIX"
fi

# Fork divergence: compare the tree object at our prefix vs the fork's root tree.
FORK_HEAD=$(git rev-parse "$REMOTE/$BRANCH")
MONO_TREE=$(git rev-parse "HEAD:$PREFIX" 2>/dev/null || echo "")
FORK_TREE=$(git rev-parse "$REMOTE/$BRANCH^{tree}" 2>/dev/null || echo "")

if [ "$MONO_TREE" = "$FORK_TREE" ]; then
    printf '  fork        \033[32min sync\033[0m (%s)\n' "${FORK_HEAD:0:12}"
else
    DIFF_STAT=$(git diff "HEAD:$PREFIX" "$REMOTE/$BRANCH" --stat 2>/dev/null || true)
    if [ -n "$DIFF_STAT" ]; then
        printf '  \033[33mfork\033[0m        \033[33mdiverged\033[0m (%s)\n' "${FORK_HEAD:0:12}"
        echo "$DIFF_STAT" | head -5 | sed 's/^/              /'
    else
        printf '  fork        \033[32min sync\033[0m (%s)\n' "${FORK_HEAD:0:12}"
    fi
fi

echo ""
