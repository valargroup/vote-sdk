[Unit]
Description=Shielded-Vote SDK chain - Validator 2 (svoted-val2)
After=network.target svoted-val1.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/shielded-vote
Environment="SVOTE_PIR_URL=http://localhost:3000"
ExecStart=/opt/shielded-vote/svoted start --home /opt/shielded-vote/.svoted-val2
Restart=on-failure

[Install]
WantedBy=multi-user.target
