[Unit]
Description=Shielded-Vote chain validator (svoted)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
EnvironmentFile=-/etc/default/svoted
ExecStart=/opt/shielded-vote/current/bin/svoted start --home /opt/shielded-vote/.svoted
Restart=on-failure
RestartSec=5
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
