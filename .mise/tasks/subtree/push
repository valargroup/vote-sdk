#!/usr/bin/env bash
#MISE description="Push subtree changes to fork feature branch and open PR"
#MISE quiet=true
set -euo pipefail

NAME="${1:-}"
if [ -z "$NAME" ]; then
    echo "Usage: mise run subtree:push <name>"
    echo "Supported: vote-nullifier-pir"
    exit 1
fi

case "$NAME" in
  vote-nullifier-pir)
    PREFIX="vote-nullifier-pir"
    REMOTE="sub-nullifier-pir"
    REPO="valargroup/vote-nullifier-pir"
    BRANCH="main"
    REMOTE_URL="git@github.com:valargroup/vote-nullifier-pir.git"
    ;;
  *)
    echo "Unknown subtree: $NAME"
    echo "Supported: vote-nullifier-pir"
    exit 1
    ;;
esac

# Ensure remote exists
if ! git remote get-url "$REMOTE" &>/dev/null; then
    printf '\033[2mAdding remote %s → %s\033[0m\n' "$REMOTE" "$REMOTE_URL"
    git remote add "$REMOTE" "$REMOTE_URL"
fi

# Bail if working tree is dirty under the prefix
DIRTY=$(git status --porcelain -- "$PREFIX/" 2>/dev/null || true)
if [ -n "$DIRTY" ]; then
    printf '\033[31mError: uncommitted changes in %s/\033[0m\n' "$PREFIX"
    echo "$DIRTY" | sed 's/^/  /'
    echo "Commit them before pushing."
    exit 1
fi

printf '\033[2mFetching %s/%s…\033[0m\n' "$REMOTE" "$BRANCH"
git fetch "$REMOTE" "$BRANCH" --quiet

# Check if there's anything to push
MONO_TREE=$(git rev-parse "HEAD:$PREFIX" 2>/dev/null || echo "")
FORK_TREE=$(git rev-parse "$REMOTE/$BRANCH^{tree}" 2>/dev/null || echo "")

if [ "$MONO_TREE" = "$FORK_TREE" ]; then
    printf '\033[32mAlready up to date.\033[0m Nothing to push to %s/%s.\n' "$REPO" "$BRANCH"
    exit 0
fi

# Build a unique feature branch name: subtree/<name>/YYYY-MM-DD[-N]
DATE=$(date +%Y-%m-%d)
FEATURE_BRANCH="subtree/${NAME}/${DATE}"
SUFFIX=1
while git ls-remote --heads "$REMOTE" "$FEATURE_BRANCH" 2>/dev/null | grep -q "$FEATURE_BRANCH"; do
    SUFFIX=$((SUFFIX + 1))
    FEATURE_BRANCH="subtree/${NAME}/${DATE}-${SUFFIX}"
done

printf 'Pushing %s/ → %s:%s…\n' "$PREFIX" "$REPO" "$FEATURE_BRANCH"
printf '\033[2m(This walks monorepo history to extract commits — may take a while.)\033[0m\n'
git subtree push --prefix="$PREFIX" "$REMOTE" "$FEATURE_BRANCH"

printf '\n\033[32mPushed.\033[0m Creating PR…\n'

# Collect recent monorepo commits touching the prefix for the PR body
COMMIT_LOG=$(git log --oneline -10 -- "$PREFIX/" 2>/dev/null || true)

PR_URL=$(gh pr create \
    --repo "$REPO" \
    --head "$FEATURE_BRANCH" \
    --base "$BRANCH" \
    --title "sync: monorepo changes $(date +%Y-%m-%d)" \
    --body "$(cat <<EOF
Synced from monorepo (\`valargroup/Shielded-Vote\`).

### Monorepo commits touching \`${PREFIX}/\`

\`\`\`
${COMMIT_LOG}
\`\`\`
EOF
)")

printf '\n\033[32mPR created:\033[0m %s\n' "$PR_URL"
